<!DOCTYPE html>
<html>
<head><title>Inregistrare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</head>
<body>
    <h2>Creeaza cont nou</h2>
    <% if (error) { %>
        <p style="color: red; font-weight: bold;">
            <%= error %>
        </p>
    <% } %>
    <form action="/register" method="POST">
        <input type="text" name="username" placeholder="Nume utilizator" required><br><br>
        <input type="email" name="email" placeholder="Email" required><br><br>
        <input type="password" name="password" placeholder="Parola" required><br><br>
        <button type="submit" class="btn btn-primary">Inregistreaza-te</button>
    </form>
    <p>Ai deja cont? <a href="/login">Logheaza-te aici</a></p>
</body>
</html>